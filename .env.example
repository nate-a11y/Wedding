# Site URLs
NEXT_PUBLIC_SITE_URL=https://nateandblake.me

# Supabase public browser client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase server-only client (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Guest/admin password auth
SITE_PASSWORD=your_guest_password
ADMIN_PASSWORD=your_admin_password
# Optional: signing secret for guest/admin session cookies. If omitted, passwords are used as fallback.
AUTH_SESSION_SECRET=your_random_session_secret

# Email - Resend fallback
RESEND_API_KEY=your_resend_api_key
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret

# Email/tasks - Microsoft Graph
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# Optional: enables Microsoft To Do realtime webhook sync
# MICROSOFT_WEBHOOK_SECRET=your_microsoft_webhook_secret

# Anti-spam / address validation
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
USPS_CONSUMER_KEY=your_usps_consumer_key
USPS_CONSUMER_SECRET=your_usps_consumer_secret

# Web push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
